def _format_option_suggestion(option_strings):
    long_opts = [opt for opt in option_strings if opt.startswith("--")]
    short_opts = [
        opt for opt in option_strings
        if opt.startswith("-") and not opt.startswith("--")
    ]
    suggestions = long_opts[:1] + short_opts[:1]
    if len(suggestions) == 1:
        return "'%s'" % suggestions[0]
    return "'%s' or '%s'" % (suggestions[0], suggestions[1])


class CamArgumentParser(argparse.ArgumentParser):
    """argparse with a guard for single-dash long-option typos."""

    def _single_dash_long_option_typos(self):
        typos = {}
        for action in getattr(self, "_actions", []):
            long_opts = [
                opt for opt in getattr(action, "option_strings", [])
                if opt.startswith("--") and len(opt) > 2
            ]
            if long_opts and getattr(action, "help", None) != argparse.SUPPRESS:
                typo = "-" + long_opts[0][2:]
                typos.setdefault(typo, list(action.option_strings))
        return typos

    def _parse_optional(self, arg_string):
        if arg_string and arg_string.startswith("-") and not arg_string.startswith("--"):
            key = arg_string.split("=", 1)[0]
            typos = self._single_dash_long_option_typos()
            if key in typos:
                self.error(
                    "unknown option '%s' (did you mean %s?)" %
                    (key, _format_option_suggestion(typos[key]))
                )
        return argparse.ArgumentParser._parse_optional(self, arg_string)



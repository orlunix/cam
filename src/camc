        "state_change": "cyan", "auto_confirm": "yellow",
        "completed": "green", "monitor_start": "blue",
    }
    headers = ["AGENT", "TIME", "EVENT", "DETAIL"]
    rows = []
    for ev in entries:
        etype = ev.get("type", "?")
        detail = ev.get("detail", {})
        if etype == "state_change":

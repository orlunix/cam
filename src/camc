#!/usr/bin/env python3
"""camc — Standalone coding agent manager CLI.

Manages AI coding agents (Claude Code, Codex, Cursor) via tmux sessions.
Auto-confirm, state detection, completion detection, background monitoring.

Single file, stdlib-only, Python 3.6+.

Quick start:
    camc init                          # First-time setup
    camc run claude "fix the tests"    # Launch an agent
    camc list                          # Show all agents
    camc logs <id> -f                  # Follow agent output
    camc attach <id>                   # Attach to tmux session
    camc stop <id>                     # Stop an agent
    camc rm <id> --kill                # Remove and kill agent
"""


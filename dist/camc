    meta = metadata or {}
    ctx = meta.get("context_window")
    if ctx is not None:
        obj["max_input_tokens"] = int(ctx)
    out = meta.get("max_output_tokens")
    if out is not None:
        obj["max_output_tokens"] = int(out)
    return obj


def openai_models_list_response(model_id, metadata=None):

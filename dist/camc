    write_codex_model_catalog(catalog_path, api_name, metadata)
    config_path = os.path.join(CODEX_API_CONFIG_DIR, "config.toml")
    content = (
        'model = "%s"\n'
        'model_provider = "%s"\n'
        'model_catalog_json = "%s"\n'
        '\n'
        '[model_providers.%s]\n'
        'name = "CAM Inference Hub Proxy"\n'

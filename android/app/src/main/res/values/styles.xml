<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Non-immersive: immersive WebView + visualViewport causes resume drift on tablets -->
    <style name="FullScreenTheme" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">#111111</item>
        <item name="android:navigationBarColor">#111111</item>
        <item name="android:windowBackground">#111111</item>
    </style>
</resources>
